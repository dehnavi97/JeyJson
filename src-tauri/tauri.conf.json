{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:3000",
    "distDir": "../dist"
  },
  "package": {
    "productName": "JeyJson",
    "version": "1.0.0"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.jeyjson.dev",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "fileAssociations": [
        {
          "ext": ["json"],
          "name": "JSON File",
          "description": "JSON Document",
          "role": "Editor"
        },
        {
          "ext": ["xml"],
          "name": "XML File",
          "description": "XML Document",
          "role": "Editor"
        },
        {
          "ext": ["yaml", "yml"],
          "name": "YAML File",
          "description": "YAML Document",
          "role": "Editor"
        },
        {
          "ext": ["txt"],
          "name": "Text File",
          "description": "Plain Text Document",
          "role": "Editor"
        }
      ]
    },
    "allowlist": {
      "all": false
    },
    "windows": [
      {
        "title": "JeyJson",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ]
  }
}
