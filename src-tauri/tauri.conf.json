{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JeyJson",
  "version": "0.1.0",
  "identifier": "ir.jeybox.jeyjson",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "JeyJson",
        "width": 1024,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true,
        "minWidth": 770,
        "minHeight": 650
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://* http://*; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["json"],
        "name": "JSON File",
        "description": "JSON Document",
        "role": "Editor"
      },
      {
        "ext": ["xml"],
        "name": "XML File",
        "description": "XML Document",
        "role": "Editor"
      },
      {
        "ext": ["yaml", "yml"],
        "name": "YAML File",
        "description": "YAML Document",
        "role": "Editor"
      },
      {
        "ext": ["txt"],
        "name": "Text File",
        "description": "Plain Text Document",
        "role": "Editor"
      }
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
